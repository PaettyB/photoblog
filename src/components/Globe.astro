---
import type { HTMLAttributes } from 'astro/types';
// import earth_img from '../assets/earth_noClouds.0330.jpg';

const {
	containerID,
	heightRatio = 1.0,
  markers = []
} = Astro.props;

---

<div id="globeViz" data-markers={JSON.stringify(markers)} data-containerID={containerID} data-height-ratio={heightRatio}></div>

<script>

	import Globe from 'globe.gl';
    
	
	 const markerSvg = `
	 	<div style="position:absolute; width: 100%; height: 100%; top: -50%">
			<svg class="geomarker" viewBox="-4 0 36 36" >
				<path fill="currentColor" d="M14,0 C21.732,0 28,5.641 28,12.6 C28,23.963 14,36 14,36 C14,36 0,24.064 0,12.6 C0,5.641 6.268,0 14,0 Z"></path>
				<circle fill="black" cx="14" cy="14" r="7"></circle>
			</svg>
		</div>`;

	const homeSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
		<path fill-rule="evenodd" clip-rule="evenodd" fill="currentColor" d="M21.4498 10.275L11.9998 3.1875L2.5498 10.275L2.9998 11.625H3.7498V20.25H20.2498V11.625H20.9998L21.4498 10.275ZM5.2498 18.75V10.125L11.9998 5.0625L18.7498 10.125V18.75H14.9999V14.3333L14.2499 13.5833H9.74988L8.99988 14.3333V18.75H5.2498ZM10.4999 18.75H13.4999V15.0833H10.4999V18.75Z"/>
		</svg>`;

	function makeMarker(text: string, color: string, size: number = 20) {
		const marker = `
			<div style="color: ${color};
				width: ${size}px;
				height: ${size}px;
				pointer-events: auto;
				cursor: pointer;">
				${markerSvg}
				<span style="position: absolute; 
					top: calc(-10px + 50% - 52px); 
					left: calc(-10px + 50% + 35px);
					padding-bottom: 15px; 
					z-index: 10;
					display: none;
					white-space: nowrap;">
						${text}
				</span>
				<div style="padding: 10px;
					position: absolute;
					width: 55px; 
					height: 55px; 
					top: calc(-10px + 50% - 35px);
					left: calc(-10px + 50%);
					display:none;
					z-index: 5;">
					<div style="
						width: 100%;
						height: 100%;
						border-top: 2px solid ${color}; 
						border-left: 2px solid ${color}; 
						transform: skewX(-30deg);
						transform-origin: bottom left;
						">
					</div>
				</div>
			</div>`;
		return marker;
	}
	
	

	const el = document.getElementById('globeViz');
  	const markers = JSON.parse(el.dataset.markers);
	const containerID = el.dataset.containerid;
	const container = document.getElementById(containerID);

	const heightRatio = parseFloat(el.dataset.heightRatio);
	const width = container.clientWidth;
	const height = width * heightRatio;

	markers.push({"lat": 48.13743, "lng": 11.57549, "label": "Home", "color": "green", "href": ""})


    const globe = new Globe(el)
		.globeImageUrl('/globe.jpg')
		// .globeImageUrl('//cdn.jsdelivr.net/npm/three-globe/example/img/earth-blue-marble.jpg')
		// .bumpImageUrl('//cdn.jsdelivr.net/npm/three-globe/example/img/earth-topology.png')
		// .globeTileEngineUrl((x, y, l) => `https://tile.openstreetmap.org/${l}/${x}/${y}.png`)
		.pointOfView({ lat: markers[0]?.lat || 35, lng: markers[0]?.lng || 11, altitude: 0.7 }, 5000)
		.backgroundColor('rgba(255,255,255,0)')
		.htmlElementsData(markers)
		.htmlElement(d => {
			if(d.label == 'Home') {
				const marker = document.createElement('div');
				marker.innerHTML = homeSvg;
				marker.style.width = '30px';
				marker.style.color =  d.color;
				return marker;
			}
			const marker = document.createElement('div');
			marker.innerHTML = makeMarker(d.label, d.color, d.size);
			const label = marker.children[0].children[1];
			const connector = marker.children[0].children[2];

			marker.onclick = () => console.info(d);
			marker.onmouseover = () => {
				label.style.display = 'block';
				connector.style.display = 'block';

				document.querySelectorAll('.geomarker').forEach(el => {
					el.style.opacity = '0.3';
				});
			};

			marker.onmouseout = () => {
				label.style.display = 'none';
				connector.style.display = 'none';

				document.querySelectorAll('.geomarker').forEach(el => {
					el.style.opacity = '1';
				});
			};
			marker.onwheel = (e) => {
				e.preventDefault();
				label.style.display = 'none';
				connector.style.display = 'none';

				document.querySelectorAll('.geomarker').forEach(el => {
					el.style.opacity = '1';
				});
			}
			return marker;
		})
		.width(width)
		.height(height);
	//   .polygonCapColor(feat => 'rgba(200, 0, 0, 0.6)')
    //   .polygonSideColor(() => 'rgba(0, 100, 0, 0.05)')

	//  fetch('/ne_110m_admin_0_countries.geojson')
	//  	.then(res => res.json())
	// 	.then(countries => {
    //   		globe.polygonsData(countries.features.filter(d => d.properties.ISO_A2 !== 'AQ'))
	// 	});

	function resizeGlobe() {
		const container = document.getElementById(containerID);
		const width = container.clientWidth;
		const height = width * heightRatio;

		globe.width(width);
		globe.height(height);
	}

  	window.addEventListener('resize', resizeGlobe);

  	resizeGlobe();

</script>


